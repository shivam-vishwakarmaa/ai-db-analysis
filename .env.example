# OpenRouter API Key (free tier — get yours at https://openrouter.ai)
VITE_GEMINI_API_KEY=you key 
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model selection (free models — priority order)
# 1st: meta-llama/llama-3.3-70b-instruct:free
# 2nd: google/gemma-3-27b-it:free
# 3rd: deepseek/deepseek-r1:free
# 4th: mistralai/mistral-small-3.1-24b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
